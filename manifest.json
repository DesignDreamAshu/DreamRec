{
  "manifest_version": 3,
  "name": "DreamRec",
  "description": "Reliable tab/screen recorder (WebM output)",
  "version": "2.0.0",
  "minimum_chrome_version": "120",
  "action": {
    "default_title": "DreamRec",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "downloads",
    "identity",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://www.googleapis.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
